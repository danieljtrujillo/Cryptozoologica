# RESEARCH: Primary API key for all Gemini AI calls.
# Set this in Cloudflare Pages env vars for production.
RESEARCH=""

# GEMINI_API_KEY: Fallback key (used if RESEARCH is not set).
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
