rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: observations
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - cryptidName: string (required) - Name of the cryptid
    //   - description: string (required) - Sighting details
    //   - location: map (required) - lat, lng, address
    //   - timestamp: timestamp (required) - When it happened
    //   - imageUrl: string (optional) - URL to photo
    //   - videoUrl: string (optional) - URL to video
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidObservation(data) {
      return data.userId is string &&
             data.cryptidName is string && data.cryptidName.size() > 0 && data.cryptidName.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.location is map &&
             data.timestamp is timestamp;
    }

    match /observations/{observationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidObservation(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid &&
                      isValidObservation(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /saved_entries/{entryId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /saved_locations/{locationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
